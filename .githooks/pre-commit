#!/usr/bin/env bash
# pre-commit hook — runs lint/format only for touched services before allowing a
# commit. Blocks the commit if lint errors are unfixable.
#
# Install once with:  git config core.hooksPath .githooks

set -euo pipefail

# ─── Colour helpers ────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Colour

# ─── Paths ─────────────────────────────────────────────────────────────────────
ROOT="$(git rev-parse --show-toplevel)"
BACKEND="$ROOT/app/backend"
FRONTEND="$ROOT/app/frontend"

# ─── Determine which files are staged ─────────────────────────────────────────
staged_files=$(git diff --cached --name-only --diff-filter=ACMR)

service_has_changes() {
  local prefix="$1"
  echo "$staged_files" | grep -q "^$prefix"
}

staged_files_for_prefix() {
  local prefix="$1"
  echo "$staged_files" | grep "^$prefix" || true
}

run_js_lint() {
  local service="$1"
  local dir="$2"
  local prefix="$3"

  if ! service_has_changes "$prefix"; then
    echo -e "  ${YELLOW}⟳ $service (lint/format)${NC}  (no staged changes — skipped)"
    return 0
  fi

  echo -e "  ${CYAN}▶ $service (lint/format)${NC}"

  if ! (cd "$dir" && make lint-fix 2>&1); then
    echo -e "  ${RED}✗ $service lint FAILED — unfixable errors; commit blocked${NC}"
    return 1
  fi

  if ! (cd "$dir" && make format-write 2>&1); then
    echo -e "  ${RED}✗ $service format FAILED — commit blocked${NC}"
    return 1
  fi

  local files_to_stage
  files_to_stage=$(staged_files_for_prefix "$prefix")
  if [ -n "$files_to_stage" ]; then
    while IFS= read -r file; do
      [ -n "$file" ] && git add -- "$file"
    done <<< "$files_to_stage"
  fi

  echo -e "  ${GREEN}✓ $service lint/format passed${NC}"
}

run_python_lint() {
  local service="ai-service"
  local dir="$BACKEND/$service"
  local prefix="app/backend/${service}/"

  if ! service_has_changes "$prefix"; then
    echo -e "  ${YELLOW}⟳ $service (lint/format)${NC}  (no staged changes — skipped)"
    return 0
  fi

  echo -e "  ${CYAN}▶ $service (lint/format)${NC}"

  if ! (cd "$dir" && make lint-fix 2>&1); then
    echo -e "  ${RED}✗ $service lint FAILED — unfixable Ruff errors; commit blocked${NC}"
    return 1
  fi

  if ! (cd "$dir" && make format-write 2>&1); then
    echo -e "  ${RED}✗ $service format FAILED — commit blocked${NC}"
    return 1
  fi

  local files_to_stage
  files_to_stage=$(staged_files_for_prefix "$prefix")
  if [ -n "$files_to_stage" ]; then
    while IFS= read -r file; do
      [ -n "$file" ] && git add -- "$file"
    done <<< "$files_to_stage"
  fi

  echo -e "  ${GREEN}✓ $service lint/format passed${NC}"
}

# ─── Main ───────────────────────────────────────────────────────────────────────
echo ""
echo -e "${CYAN}╔══════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║       pre-commit · Caret lint + tests    ║${NC}"
echo -e "${CYAN}╚══════════════════════════════════════════╝${NC}"
echo ""

failed=0

echo -e "${CYAN}── Lint & Format ──────────────────────────${NC}"
echo ""

run_js_lint "frontend" "$FRONTEND" "app/frontend/" || failed=1
run_js_lint "auth-service" "$BACKEND/auth-service" "app/backend/auth-service/" || failed=1
run_js_lint "document-service" "$BACKEND/document-service" "app/backend/document-service/" || failed=1
run_js_lint "api-gateway" "$BACKEND/api-gateway" "app/backend/api-gateway/" || failed=1
run_js_lint "collab-service" "$BACKEND/collab-service" "app/backend/collab-service/" || failed=1
run_python_lint || failed=1

echo ""
if [ "$failed" -eq 1 ]; then
  echo -e "${RED}✗ Lint/format failed. Fix the errors above and retry.${NC}"
  echo -e "${YELLOW}  To bypass (discouraged): git commit --no-verify${NC}"
  echo ""
  exit 1
fi

echo -e "${GREEN}✓ All checks passed. Proceeding with commit.${NC}"
echo ""
exit 0
