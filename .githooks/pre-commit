#!/usr/bin/env bash
# pre-commit hook — runs the full test suite for every affected microservice
# before allowing a commit. Blocks the commit if any test fails.
#
# Install once with:  git config core.hooksPath .githooks

set -euo pipefail

# ─── Colour helpers ────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Colour

# ─── Paths ─────────────────────────────────────────────────────────────────────
ROOT="$(git rev-parse --show-toplevel)"
BACKEND="$ROOT/app/backend"

# ─── Determine which services have staged changes ──────────────────────────────
# If a service directory has staged files, its tests are run; otherwise skipped.
staged_files=$(git diff --cached --name-only)

service_has_changes() {
  local service="$1"
  echo "$staged_files" | grep -q "^app/backend/$service/"
}

# ─── Node.js service runner (Vitest) ───────────────────────────────────────────
run_node_tests() {
  local service="$1"
  local dir="$BACKEND/$service"

  if ! service_has_changes "$service"; then
    echo -e "  ${YELLOW}⟳ $service${NC}  (no staged changes — skipped)"
    return 0
  fi

  echo -e "  ${CYAN}▶ $service${NC}"
  if (cd "$dir" && bun run test --run 2>&1); then
    echo -e "  ${GREEN}✓ $service passed${NC}"
  else
    echo -e "  ${RED}✗ $service FAILED — commit blocked${NC}"
    return 1
  fi
}

# ─── Python service runner (Pytest) ────────────────────────────────────────────
run_python_tests() {
  local service="$1"
  local dir="$BACKEND/$service"

  if ! service_has_changes "$service"; then
    echo -e "  ${YELLOW}⟳ $service${NC}  (no staged changes — skipped)"
    return 0
  fi

  echo -e "  ${CYAN}▶ $service${NC}"
  if (cd "$dir" && uv run pytest tests/ -q 2>&1); then
    echo -e "  ${GREEN}✓ $service passed${NC}"
  else
    echo -e "  ${RED}✗ $service FAILED — commit blocked${NC}"
    return 1
  fi
}

# ─── Main ───────────────────────────────────────────────────────────────────────
echo ""
echo -e "${CYAN}╔══════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║         pre-commit · Caret tests         ║${NC}"
echo -e "${CYAN}╚══════════════════════════════════════════╝${NC}"
echo ""

failed=0

run_node_tests   "auth-service"      || failed=1
run_node_tests   "document-service"  || failed=1
run_node_tests   "api-gateway"       || failed=1
run_node_tests   "collab-service"    || failed=1
run_python_tests "ai-service"        || failed=1

echo ""
if [ "$failed" -eq 1 ]; then
  echo -e "${RED}✗ Tests failed. Fix the errors above and retry.${NC}"
  echo -e "${YELLOW}  To bypass (discouraged): git commit --no-verify${NC}"
  echo ""
  exit 1
fi

echo -e "${GREEN}✓ All tests passed. Proceeding with commit.${NC}"
echo ""
exit 0
