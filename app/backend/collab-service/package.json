{
  "name": "@caret/collab-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format:check": "prettier --check src",
    "format:write": "prettier --write src",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.43.0",
    "jose": "^6.2.2",
    "lib0": "^0.2.110",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "ws": "^8.18.2",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.14",
    "drizzle-kit": "^0.31.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.1.4"
  }
}
