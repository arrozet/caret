# ─────────────────────────────────────────────
# PostgreSQL (local dev — Docker Compose)
# ─────────────────────────────────────────────
POSTGRES_USER=caret
POSTGRES_PASSWORD=caret
POSTGRES_DB=caret_dev

# ─────────────────────────────────────────────
# Auth / JWT
# ─────────────────────────────────────────────
# Used by auth-service, document-service, and collab-service to validate tokens.
# In production, this must match the Supabase JWT secret.
JWT_SECRET=dev_secret_change_in_production
SUPABASE_JWT_SECRET=dev_secret_change_in_production

# ─────────────────────────────────────────────
# Supabase (fill in when connecting to a real project)
# ─────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────
# AI Service — LLM API keys
# ─────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
